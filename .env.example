# Copy this file to .env and fill in real values
# NEVER commit .env to source control

# Database
DB_HOST=localhost
DB_PORT=5434
DB_NAME=mednex
DB_USERNAME=mednex
DB_PASSWORD=your_secure_password_here

# Redis (for Docker: redis / 6379)
REDIS_HOST=localhost
REDIS_PORT=6379

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password
KEYCLOAK_REALM=mednex
KEYCLOAK_CLIENT_ID=mednex-backend
KEYCLOAK_CLIENT_SECRET=your_client_secret_if_required

# Keycloak URL (Docker: http://keycloak:8080)
KEYCLOAK_URL=http://localhost:8080

# Application
APP_PDF_ENCRYPTION_KEY=your_32_byte_base64_encryption_key

# SMTP (optional, for emails)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
